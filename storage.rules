rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() { return request.auth != null; }

    function isImageUnder5MB() {
      return request.resource != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // มาตรฐานใหม่: JobPhoto/{jobId}/...
    match /JobPhoto/{jobId}/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn() && isImageUnder5MB();
    }

    // รูป cover/รูปงาน: jobs/{jobId}/{fileName}
    match /jobs/{jobId}/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn() && isImageUnder5MB();
    }

    // รูป activity: jobs/{jobId}/activity/{fileName}
    match /jobs/{jobId}/activity/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn() && isImageUnder5MB();
    }
    
    // รูปเพิ่มเติมในงาน: jobs/{jobId}/photos/{fileName}
    match /jobs/{jobId}/photos/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn() && isImageUnder5MB();
    }

    // อะไหล่: parts/...
    match /parts/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn() && isImageUnder5MB();
    }

    // รายการซื้อ: purchases/...
    match /purchases/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn() && isImageUnder5MB();
    }

    // เงินสดหน้าร้าน: cash-drawer/{sessionId}/{fileName}
    match /cash-drawer/{sessionId}/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn() && isImageUnder5MB();
    }

    // Default deny for other paths
    match /{allPaths=**} {
      allow read: if signedIn();
      allow write: if false;
    }
  }
}