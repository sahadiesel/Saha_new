rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() { return request.auth != null; }

    function isImageUnder5MB() {
      return request.resource != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // มาตรฐานใหม่: JobPhoto/{jobId}/...
    match /JobPhoto/{jobId}/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn() && isImageUnder5MB();
    }

    // รูป cover/รูปงาน: jobs/{jobId}/{fileName}
    match /jobs/{jobId}/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn() && isImageUnder5MB();
    }

    // รูป activity: jobs/{jobId}/activity/{fileName}
    match /jobs/{jobId}/activity/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn() && isImageUnder5MB();
    }
    
    // รูปเพิ่มเติมในงาน: jobs/{jobId}/photos/{fileName}
    match /jobs/{jobId}/photos/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn() && isImageUnder5MB();
    }

    // อะไหล่: parts/...
    match /parts/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn() && isImageUnder5MB();
    }

    // รายการซื้อ: purchases/...
    match /purchases/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn() && isImageUnder5MB();
    }

    // เงินสดหน้าร้าน: cash-drawer/{sessionId}/{fileName}
    match /cash-drawer/{sessionId}/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn() && isImageUnder5MB();
    }

    // เอกสารแนบใบลา: พนักงานสร้างได้เฉพาะโฟลเดอร์ของตนเอง ไม่อนุญาตแก้ไข/ลบไฟล์
    match /hrLeaveAttachments/{userId}/{leaveId}/{fileName} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == userId && isImageUnder5MB();
      allow update, delete: if false;
    }

    // รูปบัตรประชาชน (ลงทะเบียนพอร์ทัลลูกค้า) — อัปโหลดหลังสมัครด้วย uid ตนเอง, อ่านผ่าน signed URL จาก Admin เท่านั้น
    match /customerPortalIdCards/{customerId}/{userId}/{fileName} {
      allow read: if false;
      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.size <= 512 * 1024
        && request.resource.contentType.matches('image/.*');
      allow update, delete: if false;
    }

    function isNotCustomerPortalIdCardPath() {
      return !resource.name.matches('^customerPortalIdCards/.+');
    }

    // Default deny for other paths
    match /{allPaths=**} {
      allow read: if signedIn() && isNotCustomerPortalIdCardPath();
      allow write: if false;
    }
  }
}