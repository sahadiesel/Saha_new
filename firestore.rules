
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===================================
    // Helper Functions
    // ===================================
    function signedIn() {
      return request.auth != null;
    }
    
    function isSystemAdmin() {
      return request.auth.uid == "oh3jF10Am4PPGelNzFhjWX6GE5E2";
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function role() {
      return userExists() ? getProfile().role : '';
    }
    function dept() {
      return userExists() ? getProfile().department : '';
    }
    
    function isViewer() {
      return signedIn() && role() == "VIEWER";
    }

    function isAdmin() {
      return isSystemAdmin() || (signedIn() && role() == "ADMIN");
    }

    function isMgmt() {
      return isSystemAdmin() || (signedIn() && (dept() == "MANAGEMENT" || role() == "ADMIN" || role() == "MANAGER"));
    }

    function canEditJobs() {
      return signedIn() && role() != "VIEWER" && (
        role() == "ADMIN" || 
        role() == "MANAGER" || 
        role() == "OFFICER" ||
        dept() == "MANAGEMENT" || 
        dept() == "OFFICE" || 
        dept() == "PURCHASING" || 
        dept() == "ACCOUNTING_HR" || 
        dept() == "CAR_SERVICE" || 
        dept() == "COMMONRAIL" || 
        dept() == "MECHANIC" || 
        dept() == "OUTSOURCE"
      );
    }

    /** ฟิลด์ขั้นต่ำหลังสมัครพอร์ทัล — ใช้ is string กันบางเอกสารเก่าทำให้ rule ล้มแบบ PERMISSION_DENIED */
    function customerPortalCustomerPayloadOk(customerId) {
      return request.resource.data.keys().hasAll(['name', 'phone', 'authUid'])
        && request.resource.data.name is string && request.resource.data.name.size() > 0 && request.resource.data.name.size() < 200
        && request.resource.data.phone is string && request.resource.data.phone == customerId
        && request.resource.data.authUid is string && request.resource.data.authUid == request.auth.uid;
    }

    /** ลูกค้าสร้าง/ผูกเอกสาร customers/{เบอร์} หลังสมัคร — ใช้ร่วมกับ batch เขียนคู่กับ users */
    function customerSelfCreate(customerId) {
      return signedIn() && userExists() && !isViewer()
        && role() == "CUSTOMER"
        && getProfile().phone == customerId
        && customerPortalCustomerPayloadOk(customerId);
    }

    function customerSelfServiceUpdate(customerId) {
      return signedIn() && userExists() && !isViewer()
        && role() == "CUSTOMER"
        && getProfile().phone == customerId
        && customerPortalCustomerPayloadOk(customerId)
        && (
          resource.data.authUid == request.auth.uid
          || !('authUid' in resource.data)
          || resource.data.authUid == null
          || resource.data.authUid == ''
        );
    }

    /** เบอร์/รหัสลูกค้าในโปรไฟล์ — coerce เป็น string กันงานเก็บ customerId เป็นเลขหรือโปรไฟล์เก็บ phone คนละชนิด */
    function profilePhoneStr() {
      return userExists() && 'phone' in getProfile() && getProfile().phone != null
        ? string(getProfile().phone)
        : '';
    }

    /** customerId บนเอกสารงาน (path jobs/{jobId}) */
    function jobCustomerIdStrByJobId(jobId) {
      let d = get(/databases/$(database)/documents/jobs/$(jobId)).data;
      return 'customerId' in d && d.customerId != null ? string(d.customerId) : '';
    }

    /** ลูกค้าเป็นเจ้าของงาน (เทียบเบอร์ในเอกสารงาน) */
    function customerOwnsJobDoc() {
      return signedIn() && userExists() && role() == "CUSTOMER"
        && profilePhoneStr().size() > 0
        && 'customerId' in resource.data && resource.data.customerId != null
        && string(resource.data.customerId) == profilePhoneStr();
    }

    /** ลูกค้าอนุมัติ/ไม่อนุมัติใบเสนอราคา — เปลี่ยนได้เฉพาะสถานะ WAITING_APPROVE */
    function customerJobQuotationDecisionUpdate() {
      return customerOwnsJobDoc()
        && resource.data.status == 'WAITING_APPROVE'
        && 'customerId' in request.resource.data
        && request.resource.data.customerId != null
        && string(request.resource.data.customerId) == string(resource.data.customerId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'lastActivityAt', 'updatedAt'])
        && (
          request.resource.data.status == 'PENDING_PARTS'
          || request.resource.data.status == 'DONE'
        );
    }

    function customerOwnsJobById(jobId) {
      return signedIn() && userExists() && role() == "CUSTOMER"
        && exists(/databases/$(database)/documents/jobs/$(jobId))
        && profilePhoneStr().size() > 0
        && jobCustomerIdStrByJobId(jobId).size() > 0
        && jobCustomerIdStrByJobId(jobId) == profilePhoneStr();
    }
    
    function isOfficeOrMgmt() {
      return (isMgmt() || (signedIn() && (dept() == "OFFICE" || role() == "ADMIN" || role() == "MANAGER" || role() == "OFFICER"))) && !isViewer();
    }
    
    function isAccountingAllowed() {
      return isOfficeOrMgmt() || (signedIn() && dept() == "ACCOUNTING_HR");
    }

    function isHRAllowed() {
      return isMgmt() || (signedIn() && dept() == "ACCOUNTING_HR");
    }
    
    function isPurchasingAllowed() {
      return isMgmt() || (signedIn() && (dept() == "PURCHASING" || dept() == "OFFICE" || role() == "PURCHASE"));
    }

    /** ชื่อคอลเลกชัน archive ปีละไฟล์ — ใช้ matches() (มี startsWith() ในกฎไม่รองรับ → linter เตือน) */
    function isJobsArchiveCollection(name) {
      return name.matches('^jobsArchive_.*');
    }

    /** ลูกค้าห้ามเปลี่ยน phone / role / status / email เอง — อนุมัติผ่าน Admin */
    function customerSelfUserUpdateOk() {
      return role() != 'CUSTOMER' || (
        resource.data.phone == request.resource.data.phone &&
        resource.data.role == request.resource.data.role &&
        resource.data.status == request.resource.data.status &&
        resource.data.email == request.resource.data.email
      );
    }

    /** อนุมัติพอร์ทัลลูกค้า (PENDING → ACTIVE) เฉพาะ Admin เท่านั้น — HR/Manager ทำไม่ได้ */
    function customerPortalApprovalAllowed() {
      return !(resource.data.role == 'CUSTOMER'
        && resource.data.status == 'PENDING'
        && request.resource.data.status == 'ACTIVE')
        || isAdmin();
    }

    // ===================================
    // Default Security Rules
    // ===================================
    match /{document=**} {
      allow read: if signedIn();
      allow write: if isAdmin(); // System default fallback
    }

    // ===================================
    // Collection-Specific Rules
    // ===================================

    // User Profiles
    match /users/{uid} {
      allow read: if signedIn();
      allow create: if !isViewer() && (isHRAllowed() || (signedIn() && request.auth.uid == uid));
      allow update: if !isViewer() && customerPortalApprovalAllowed() && (
        isHRAllowed() ||
        (signedIn() && request.auth.uid == uid && customerSelfUserUpdateOk())
      );
      allow delete: if isAdmin();

      /** เวลาอ่านแชตลูกค้าต่อ job (ต่อผู้ใช้) — map reads.{jobId} = timestamp */
      match /jobCustomerChatReads/{readDocId} {
        allow read: if signedIn() && request.auth.uid == uid;
        allow create, update: if signedIn() && request.auth.uid == uid && canEditJobs() && !isViewer() && readDocId == 'summary';
        allow delete: if false;
      }
    }

    // Settings
    match /settings/{docId} {
      allow read: if docId == "landingPage" || signedIn();
      allow write: if isMgmt();
    }

    // Cash Drawer
    match /cashDrawerSessions/{sessionId} {
      allow read: if signedIn();
      allow create, update: if isOfficeOrMgmt();
      allow delete: if isAdmin();
      
      match /transactions/{transId} {
        allow read: if signedIn();
        allow create: if isOfficeOrMgmt() && request.resource.data.amount > 0;
        allow update, delete: if isMgmt();
      }
    }

    // Customers & Vendors
    match /customers/{id} {
      allow read: if signedIn();
      allow create: if (canEditJobs() && request.resource.data.name.size() < 200)
        || customerSelfCreate(id);
      allow update: if (canEditJobs() && request.resource.data.name.size() < 200)
        || customerSelfServiceUpdate(id);
      allow delete: if isAdmin();
    }
    match /vendors/{id} {
      allow read: if signedIn();
      allow create, update: if canEditJobs() && request.resource.data.companyName.size() < 200;
      allow delete: if isAdmin();
    }

    // Jobs & Main Documents
    match /jobs/{jobId} {
      allow read: if signedIn() && (
        role() != 'CUSTOMER'
        || (profilePhoneStr().size() > 0
          && 'customerId' in resource.data
          && resource.data.customerId != null
          && string(resource.data.customerId) == profilePhoneStr())
      );
      // เปิดงานใหม่ต้องใช้รหัสเอกสารแบบ auto-id ของ Firestore (20 ตัว) เท่านั้น
      // กันสร้าง jobs/SJ2026-0001 ซ้ำแล้วไปดึงเอกสารเก่าที่ผูก jobId เดิม — ยกเว้นแอดมิน (เช่น กู้คืนจากประวัติ)
      allow create: if signedIn() && !isViewer() && request.resource.data.photos.size() <= 4
        && (jobId.size() == 20 || isAdmin());
      // ฝ่ายบริหาร/แอดมินอัปเดตงานได้แม้รูปเกิน 4 (เครื่องมือแก้สถานะจะไม่ถูกบล็อก)
      allow update: if (canEditJobs() && (
        isMgmt() ||
        !('photos' in request.resource.data) ||
        (request.resource.data.photos is list && request.resource.data.photos.size() <= 4)
      )) || customerJobQuotationDecisionUpdate();
      allow delete: if isMgmt();
      match /activities/{activityId} {
        allow read: if signedIn() && (
          role() != 'CUSTOMER'
          || (
            profilePhoneStr().size() > 0
            && jobCustomerIdStrByJobId(jobId).size() > 0
            && jobCustomerIdStrByJobId(jobId) == profilePhoneStr()
          )
        );
        allow create: if signedIn() && !isViewer()
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() < 5000
          && (!('photos' in request.resource.data) || request.resource.data.photos.size() <= 10)
          && (
            role() != 'CUSTOMER'
            || (
              profilePhoneStr().size() > 0
              && jobCustomerIdStrByJobId(jobId).size() > 0
              && jobCustomerIdStrByJobId(jobId) == profilePhoneStr()
            )
          );
        allow update: if canEditJobs();
        /** ลบทั้งเอกสารกิจกรรม — เฉพาะ ADMIN (ลบรูปทีละรูปยังใช้ update ตามเดิม) */
        allow delete: if isAdmin();
      }
      match /customerChat/{msgId} {
        allow read: if signedIn() && (
          role() != 'CUSTOMER'
          || customerOwnsJobById(jobId)
        );
        allow create: if signedIn() && !isViewer()
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() < 4000
          && (request.resource.data.authorRole == 'CUSTOMER' || request.resource.data.authorRole == 'STAFF')
          && request.resource.data.userName is string
          && request.resource.data.userId == request.auth.uid
          && (
            (role() == 'CUSTOMER'
              && request.resource.data.authorRole == 'CUSTOMER'
              && customerOwnsJobById(jobId))
            || (canEditJobs() && request.resource.data.authorRole == 'STAFF')
          );
        allow update, delete: if false;
      }
    }
    
    // Archive Collections
    match /{collectionName}/{jobId} {
        allow read: if signedIn() && isJobsArchiveCollection(collectionName)
          && (
            role() != 'CUSTOMER'
            || (
              profilePhoneStr().size() > 0
              && 'customerId' in resource.data
              && resource.data.customerId != null
              && string(resource.data.customerId) == profilePhoneStr()
            )
          );
        allow create, update, delete: if isMgmt() && isJobsArchiveCollection(collectionName);
        match /activities/{activityId} {
            allow read: if signedIn() && isJobsArchiveCollection(collectionName)
              && (
                role() != 'CUSTOMER' ||
                profilePhoneStr().size() > 0
                && get(/databases/$(database)/documents/$(collectionName)/$(jobId)).data.customerId != null
                && string(get(/databases/$(database)/documents/$(collectionName)/$(jobId)).data.customerId) == profilePhoneStr()
              );
            allow write: if isMgmt() && isJobsArchiveCollection(collectionName);
        }
    }

    match /documents/{docId} {
      allow read: if signedIn();
      allow create: if signedIn() && !isViewer() && request.resource.data.items.size() <= 50;
      allow update: if (isAccountingAllowed() || signedIn()) && !isViewer() && request.resource.data.items.size() <= 50;
      allow delete: if isAdmin();
    }
    
    match /documentCounters/{yearId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && !isViewer();
      allow delete: if isAdmin();
    }

    match /purchaseDocs/{docId} {
      allow read: if signedIn();
      allow create: if signedIn() && !isViewer() && request.resource.data.items.size() <= 50;
      allow update: if signedIn() && !isViewer() && request.resource.data.items.size() <= 50;
      allow delete: if isAdmin();
    }
    
    match /purchaseClaims/{claimId} {
        allow read, create, update: if isAccountingAllowed();
        allow delete: if isAdmin();
    }

    match /accountingAccounts/{id} {
      allow read, write: if isAccountingAllowed();
    }
    
    match /accountingEntries/{id} {
      allow read, create, update: if isAccountingAllowed();
      allow delete: if isMgmt();
    }
    
    match /accountingObligations/{id} {
      allow read, create, update: if isAccountingAllowed();
      allow delete: if isMgmt();
    }

    match /accountingCheckItems/{id} {
      allow read, create, update, delete: if isAccountingAllowed();
    }
    
    match /billingRuns/{monthId} {
        allow read, write: if isAccountingAllowed();
    }

    match /arPayments/{id} {
      allow read, write: if isAccountingAllowed();
    }

    match /parts/{partId} {
      allow read: if signedIn() || resource.data.showOnWeb == true;
      allow create, update: if isPurchasingAllowed();
      allow delete: if isMgmt();
    }

    match /stockActivities/{id} {
      allow read: if signedIn();
      allow create: if isPurchasingAllowed();
      allow update, delete: if isAdmin();
    }

    match /partLocations/{id} {
      allow read: if signedIn();
      allow create, update: if isPurchasingAllowed();
      allow delete: if isMgmt();
    }

    match /partCategories/{id} {
      allow read: if signedIn() || true; // Public read categories for web catalog
      allow create, update: if isPurchasingAllowed();
      allow delete: if isMgmt();
    }

    match /attendance/{id} { allow read, write: if signedIn(); }
    match /kioskTokens/{id} {
      allow read, create, update: if true;
      allow delete: if isAdmin(); 
    }
    
    match /hrHolidays/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
    
    match /hrAttendanceAdjustments/{id} {
      allow read: if isHRAllowed();
      allow write: if isHRAllowed();
    }
    
    match /ssoHospitals/{hospitalId} {
      allow read: if signedIn();
      allow write: if isHRAllowed();
    }
    
    match /hrLeaves/{id} {
        allow read: if isHRAllowed() || (signedIn() && request.auth.uid == resource.data.userId);
        allow create: if signedIn() && !isViewer();
        allow update: if (isHRAllowed() || (signedIn() && request.auth.uid == resource.data.userId)) && !isViewer();
        allow delete: if isAdmin();
    }

    match /payrollBatches/{batchId} {
      allow read, write: if isHRAllowed();
      match /payslips/{userId} {
        allow read: if (signedIn() && request.auth.uid == userId) || isHRAllowed();
        allow write: if (isHRAllowed() || (signedIn() && request.auth.uid == userId)) && !isViewer();
      }
    }

    match /quotationTemplates/{id} {
      allow read: if signedIn();
      allow write: if isOfficeOrMgmt() && request.resource.data.items.size() <= 50;
    }
  }
}
